# Database
DATABASE_URL=postgresql+asyncpg://podking:podking@localhost:5432/podking

# Session
SESSION_SECRET_KEY=change-me-at-least-32-random-bytes

# Fernet key — generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=change-me-generate-a-real-one

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback

# App
APP_BASE_URL=http://localhost:8000
ALLOWED_EMAILS=you@example.com
MAX_DURATION_SECONDS=14400
AUDIO_STORAGE_PATH=./data/audio
LOG_LEVEL=INFO
